<% layout("../layout/boilerplate.ejs") -%>

<main class="inner-page about-page">
      <section class="about-content">
        <div class="section-heading banner-heading">
          <h2>Meet the Visionaries</h2>
          <p>The passionate team dedicated to shaping the future of education.</p>
        </div>
        
        <div class="founders-section">
          <div class="founder-card">
            <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=900&q=80" alt="Founder Aisha Rahman">
            <div class="founder-content">
              <h2>Aisha Rahman</h2>
              <span>Co-Founder & Learning Strategist</span>
              <p>Aisha shapes curriculum experiences that help students move from confusion to structured progress smoothly.</p>
            </div>
          </div>

          <div class="founder-card">
            <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=900&q=80" alt="Founder Daniel Joseph">
            <div class="founder-content">
              <h2>Daniel Joseph</h2>
              <span>Co-Founder & Technology Lead</span>
              <p>Daniel focuses on clean digital tools that help institutions present academic options with zero friction.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="stats-section">
        <div class="stat-card">
          <span class="stat-num">50K+</span>
          <span class="stat-label">Future Leaders Guided</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">120+</span>
          <span class="stat-label">World-Class Mentors</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">95%</span>
          <span class="stat-label">Career Progression Rate</span>
        </div>
      </section>
    </main>